{
  "name": "salesforce-e2e-tests",
  "version": "1.0.0",
  "description": "Pruebas E2E de regresión para Salesforce con UTAM + WebdriverIO",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "compile": "utam -c utam.config.js",
    "test": "wdio run wdio.conf.js",
    "test:compile-and-run": "npm run compile && npm run test"
  },
  "devDependencies": {
