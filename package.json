    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "wdio-chromedriver-service": "^8.1.1",
    "wdio-utam-service": "3.3.0",
    "utam": "3.3.0",
    "salesforce-pageobjects": "latest",
    "dotenv": "^16.4.0",
    "chromedriver": "^147.0.0"
  }
}